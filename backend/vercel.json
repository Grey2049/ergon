{
    "version": 2,
    "builds": [
        {
            "src": "app/main.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb",
                "runtime": "python3.12"
            }
        }
    ],
    "routes": [
        {
            "src": "/health",
            "dest": "app/main.py"
        },
        {
            "src": "/api/(.*)",
            "dest": "app/main.py"
        }
    ],
    "env": {
        "ENVIRONMENT": "production"
    }
}