# =============================================================================
# Application Configuration
# =============================================================================
SERVICE_NAME=Ergon
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8007
RELOAD=true

# =============================================================================
# S3 / CDN Configuration
# =============================================================================
S3_BUCKET_NAME=cdn.newtonco.ai
S3_ASSETS_PATH=assets/ergon/{environment}/{upload_type}/
CDN_BASE_URL=https://cdn.newtonco.ai/
PRESIGNED_URL_EXPIRATION=3600
MAX_UPLOAD_SIZE_MB=10

# AWS Credentials (optional — boto3 falls back to env vars / instance profile)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=us-east-1

# =============================================================================
# Figma API
# =============================================================================
FIGMA_API_TOKEN=
FIGMA_TEAM_ID=

# =============================================================================
# Google Gemini (used for parsing screenshots / files)
# =============================================================================
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# =============================================================================
# Slack Notifications
# =============================================================================
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# =============================================================================
# Retry / Resilience
# =============================================================================
API_CLIENT_MAX_RETRIES=3
API_CLIENT_BASE_DELAY=500
API_CLIENT_MAX_BACKOFF=8000
