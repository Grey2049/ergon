# Backend API base URL
# Leave empty to use Vite proxy (default for local dev)
# Set to full URL for direct backend calls or production
# Examples:
#   VITE_API_BASE_URL=              (uses Vite proxy -> localhost:8007)
#   VITE_API_BASE_URL=http://localhost:8007  (direct, needs CORS)
#   VITE_API_BASE_URL=https://api.ergon.ai   (production)
VITE_API_BASE_URL=
